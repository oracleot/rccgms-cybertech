{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/process-notifications",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/publish-scheduled-posts",
      "schedule": "*/5 * * * *"
    }
  ]
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/process-notifications",
      "schedule": "0 7 * * *",
      "comment": "Runs daily at 7 AM UTC. Upgrade to Vercel Pro for more frequent scheduling."
    }
  ]
}

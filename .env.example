# ============================================
# Cyber Tech - Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ===================
# Supabase Configuration
# ===================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================
# OpenAI Configuration
# ===================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ===================
# Email Notifications (Resend)
# ===================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ===================
# SMS Notifications (Telnyx)
# ===================
# Get from: https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=KEY...
TELNYX_FROM_NUMBER=+1234567890
TELNYX_MESSAGING_PROFILE_ID=...

# ===================
# Google Drive Integration (Social Media Module)
# ===================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/social/callback/google

# ===================
# Application Configuration
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cyber Tech

# ===================
# Cron Job Security
# ===================
# Generate a secure random string for cron job authentication
CRON_SECRET=generate-secure-secret

# ===================
# Rate Limiting (Optional - for production)
# ===================
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...

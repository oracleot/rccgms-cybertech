# PIC-Core Environment Configuration

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# PIC Configuration
DEFAULT_PIC_PROFILE=pic-mini

# Logging
LOG_LEVEL=info

# AI Model Provider Configuration
# Primary: OpenRouter (recommended for startup)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: OpenAI (for direct OpenAI access)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Index Service Configuration (future integration)
INDEX_SERVICE_URL=http://localhost:3003
INDEX_SERVICE_API_KEY=your_index_service_key_here

# Service Authentication (for inter-service communication)
SERVICE_API_KEY=acroniq-pic-service-key-2025

# Monitoring Configuration
ENABLE_MONITORING=true
METRICS_RETENTION_DAYS=30
ALERT_THRESHOLDS_RESPONSE_TIME_MS=10000
ALERT_THRESHOLDS_CONFIDENCE_PERCENT=60
ALERT_THRESHOLDS_ERROR_RATE=0.1

# Database Configuration (for persistent metrics, future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/pic_metrics

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Development Settings
DEBUG_PIC_ANALYSIS=false
ENABLE_FRAMEWORK_LOGGING=false
